# ── Required ───────────────────────────────────────────────────────────────────
# GCP project that hosts all resources
SAFEGUARD_PROJECT=my-gcp-project

# Vertex AI endpoint ID — set this AFTER running `terraform apply` in terraform/
# Get it from: terraform -chdir=terraform output endpoint_id
SAFEGUARD_ENDPOINT=1234567890123456789

# ── Optional (defaults shown) ──────────────────────────────────────────────────
# GCP region. Must match the region used in terraform/ and setup.sh.
SAFEGUARD_REGION=europe-west2

# BigQuery dataset name
SAFEGUARD_DATASET=safeguard

# Artifact Registry repository name (created by setup.sh)
SAFEGUARD_REPO=safeguard

# Cloud Build staging bucket (created by setup.sh)
# Defaults to: ${SAFEGUARD_PROJECT}-cloudbuild-${SAFEGUARD_REGION}
# SAFEGUARD_BUILD_BUCKET=my-gcp-project-cloudbuild-europe-west2

# Cloud Run Job name
SAFEGUARD_JOB=safeguard-classifier

# Maximum characters to send per prompt (keeps total tokens under 4096)
SAFEGUARD_MAX_INPUT_CHARS=6000

# Parallel classification workers inside the container
# SAFEGUARD_WORKERS=16
